<Window x:Class="MiranteWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:MiranteWPF.ViewModels"
        xmlns:views="clr-namespace:MiranteWPF.Views"
        Title="📚 Mirante Library System" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:AddBookViewModel}">
            <views:AddBookView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f2027" Offset="0"/>
                <GradientStop Color="#203a43" Offset="0.5"/>
                <GradientStop Color="#2c5364" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <ContentControl Content="{Binding CurrentViewModel}" Margin="20"/>
    </Grid>
</Window>
